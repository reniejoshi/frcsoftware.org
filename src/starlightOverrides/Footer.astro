---
import { mdiGithub } from '@mdi/js';
import MdiIcon from '../components/MdiIcon.astro';
import Pagination from 'virtual:starlight/components/Pagination';

// mdi doesn't have a discord icon so we're inlining our own
const mdiDiscord =
    'M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.09.09 0 0 0-.07.03c-.18.33-.39.76-.53 1.09a16.09 16.09 0 0 0-4.8 0c-.14-.34-.35-.76-.54-1.09c-.01-.02-.04-.03-.07-.03c-1.5.26-2.93.71-4.27 1.33c-.01 0-.02.01-.03.02c-2.72 4.07-3.47 8.03-3.1 11.95c0 .02.01.04.03.05c1.8 1.32 3.53 2.12 5.24 2.65c.03.01.06 0 .07-.02c.4-.55.76-1.13 1.07-1.74c.02-.04 0-.08-.04-.09c-.57-.22-1.11-.48-1.64-.78c-.04-.02-.04-.08-.01-.11c.11-.08.22-.17.33-.25c.02-.02.05-.02.07-.01c3.44 1.57 7.15 1.57 10.55 0c.02-.01.05-.01.07.01c.11.08.22.17.34.25c.04.03.04.09-.01.11c-.52.31-1.07.56-1.64.78c-.04.01-.05.06-.04.09c.32.61.67 1.19 1.07 1.74c.03.01.06.02.09.01c1.72-.53 3.45-1.33 5.25-2.65c.02-.01.03-.03.03-.05c.44-4.53-.73-8.46-3.1-11.95c-.01-.01-.02-.02-.04-.02zM8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.84 2.12-1.89 2.12zm6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.83 2.12-1.89 2.12z';
---

<footer class="site-footer">
    <!-- Pagination Navigation -->
    <div class="pagination-wrapper">
        <Pagination />
    </div>

    <div class="site-footer-inner">
        <div class="footer-startup-status">
            <a
                href="https://github.com/frcsoftware/frcsoftware.org"
                class="footer-social-link"
                target="_blank"
                rel="noreferrer"
                aria-label="Open FRCSoftware.org on GitHub"
            >
                <MdiIcon
                    class="footer-social-icon"
                    path={mdiGithub}
                    size={28}
                />
            </a>
            <a
                href="https://discord.gg/uUugPrPZFs"
                class="footer-social-link"
                target="_blank"
                rel="noreferrer"
                aria-label="Join the FRCSoftware.org Discord"
            >
                <MdiIcon
                    class="footer-social-icon"
                    path={mdiDiscord}
                    size={28}
                />
            </a>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        margin-top: 4rem;
        padding: 0 0 2.5rem;
        background: var(--sl-color-bg);
    }

    .pagination-wrapper {
        max-width: var(--sl-content-width, 72rem);
        margin: 0 auto 2rem;
        padding: 0 2rem;
    }

    .pagination-wrapper :global(nav) {
        padding-top: 1.5rem;
        border-top: 1px solid var(--sl-color-gray-6);
    }

    .site-footer-inner {
        max-width: var(--sl-content-width, 72rem);
        margin: 0 auto;
        padding: 2rem 2rem 0;
        color: var(--sl-color-gray-2);
        font-size: var(--sl-text-sm, 0.875rem);
        border-top: 1px solid var(--sl-color-gray-6);
    }

    .footer-startup-status {
        text-align: center;
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    .footer-powered-label {
        margin: 0 0 0.75rem;
        font-size: 0.95rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sl-color-gray-2);
    }

    .footer-subtext {
        margin: 0;
        color: var(--sl-color-gray-3);
    }

    .footer-social-link {
        margin-top: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--sl-color-gray-2);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    .footer-social-link:hover,
    .footer-social-link:focus-visible {
        color: var(--sl-color-white);
    }

    .footer-social-icon {
        width: 28px;
        height: 28px;
        display: block;
    }

    @media (max-width: 768px) {
        .site-footer-inner {
            padding: 0 1.25rem;
        }
    }
</style>
